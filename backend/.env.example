# ==============================================================================
# Backend Control API Environment Variables
# Rename this file to .env and configure as needed.
# ==============================================================================

# Database connection URL (used by Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/distributed_scheduler?schema=public"

# JWT configuration for user authentication
JWT_SECRET="superSecretJwtKeyForAuthentication"
JWT_EXPIRATION="1d"

# NestJS Server Port
PORT=3000
