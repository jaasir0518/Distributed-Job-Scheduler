# ==============================================================================
# Worker Service Environment Variables
# Rename this file to .env and configure as needed.
# ==============================================================================

# Database connection URL (used by Prisma to broker pending jobs)
DATABASE_URL="postgresql://postgres:password@localhost:5432/distributed_scheduler?schema=public"

# Worker Identification Name (registers to database for heartbeat checks)
WORKER_NAME="main-worker-instance"

# Concurrency capacity for this worker node
WORKER_CONCURRENCY=10
