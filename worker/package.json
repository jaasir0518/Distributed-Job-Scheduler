{
  "name": "worker",
  "version": "1.0.0",
  "description": "Standalone Distributed Job Scheduler Worker Service",
  "main": "src/main.ts",
  "scripts": {
    "start": "ts-node src/main.ts",
    "start:dev": "ts-node-dev --respawn src/main.ts",
    "dev": "npm run start:dev",
    "build": "tsc",
    "generate": "prisma generate --schema=../backend/prisma/schema.prisma",
    "test:e2e": "ts-node src/test-e2e.ts",
    "test:load-balancing": "ts-node src/test-load-balancing.ts",
    "check-db": "ts-node src/check-db.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cron-parser": "^5.6.1",
    "dotenv": "^16.4.5",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
